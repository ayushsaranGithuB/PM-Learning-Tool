---
type Reading = {
  title: string;
  url: string;
  required: boolean;
};

type Props = {
  items: Reading[];
  lessonSlug: string;
};

const { items, lessonSlug } = Astro.props;
---

<section>
  <h2>Recommended Reading</h2>
  {
    items.length > 0 ? (
      <>
        <div class="reading-progress" data-reading-progress>
          <div class="reading-progress-bar">
            <div class="reading-progress-fill" data-reading-progress-fill />
          </div>
          <span class="reading-progress-text" data-reading-progress-text>
            0 / 0 read
          </span>
        </div>
        <ul class="checklist">
          {items.map((item) => {
            const storageKey = `pm-reading:${lessonSlug}:${item.url}`;
            return (
              <li class="flex items-center gap-4 ">
                <label class="reading-checkbox" data-tooltip="Mark as read">
                  <input
                    type="checkbox"
                    class="reading-checkbox-input"
                    data-reading-checkbox
                    data-key={storageKey}
                    aria-label={`Mark "${item.title}" as read`}
                  />
                  <span class="reading-checkbox-indicator" />
                </label>
                <a
                  href={item.url}
                  target="_blank"
                  rel="noreferrer"
                  class="block flex flex-col flex-1 !no-underline"
                >
                  {item.title}
                  <br />
                  <span class="text-sm">{item.url}</span>
                </a>
                <span
                  class:list={[
                    "pill",
                    item.required ? "pill--solid" : "pill--muted",
                  ]}
                >
                  {item.required ? "Required" : "Optional"}
                </span>
              </li>
            );
          })}
        </ul>
      </>
    ) : (
      <p class="lesson-panel__empty">No external reading added yet.</p>
    )
  }
</section>

<script is:inline define:vars={{ lessonSlug }}>
  const lessonKey = "pm-reading:" + lessonSlug;

  function updateLessonProgress() {
    const containers = document.querySelectorAll("[data-reading-progress]");
    if (!containers.length) return;

    const checkboxes = document.querySelectorAll("[data-reading-checkbox]");
    const total = checkboxes.length;
    const checked = Array.from(checkboxes).filter((cb) => cb.checked).length;
    const pct = total > 0 ? (checked / total) * 100 : 0;

    containers.forEach((container) => {
      const fill = container.querySelector("[data-reading-progress-fill]");
      const text = container.querySelector("[data-reading-progress-text]");
      if (fill) fill.style.width = `${pct}%`;
      if (text) text.textContent = `${checked} / ${total} read`;
    });
  }

  function loadSavedState() {
    const checkboxes = document.querySelectorAll("[data-reading-checkbox]");
    checkboxes.forEach((cb) => {
      const key = cb.getAttribute("data-key");
      if (key && localStorage.getItem(key) === "true") {
        cb.checked = true;
      }
    });
    updateLessonProgress();
  }

  function attachListeners() {
    document.querySelectorAll("[data-reading-checkbox]").forEach((cb) => {
      // Avoid attaching duplicate listeners
      if (cb.dataset.readingListenerAttached) return;
      cb.dataset.readingListenerAttached = "true";

      cb.addEventListener("change", () => {
        const key = cb.getAttribute("data-key");
        if (key) {
          if (cb.checked) {
            localStorage.setItem(key, "true");
          } else {
            localStorage.removeItem(key);
          }
        }
        updateLessonProgress();
        window.dispatchEvent(new CustomEvent("reading-progress-update"));
      });
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    loadSavedState();
    attachListeners();
  });

  // Re-scan when inline links are enhanced by the page script
  window.addEventListener("inline-links-enhanced", () => {
    loadSavedState();
    attachListeners();
  });
</script>
