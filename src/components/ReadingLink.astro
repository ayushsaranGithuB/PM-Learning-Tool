---
type Props = {
  href: string;
  lessonSlug: string;
  title?: string;
  tags?: string[];
};

const { href, lessonSlug, title, tags } = Astro.props;
const storageKey = `pm-reading:${lessonSlug}:${href}`;
---

<div class="reading-link-wrapper" data-reading-wrapper>
  <label class="reading-checkbox" data-tooltip="Mark as read">
    <input
      type="checkbox"
      class="reading-checkbox-input"
      data-reading-checkbox
      data-key={storageKey}
      aria-label={title ? `Mark "${title}" as read` : "Mark this link as read"}
    />
    <span class="reading-checkbox-indicator"></span>
  </label>
  <a
    href={href}
    target="_blank"
    rel="noreferrer"
    class="block flex flex-col !no-underline"
    data-reading-link
  >
    <span class="text-lg font-semibold !no-underline">
      {title ?? title}
    </span>
    <span class="underline text-accent font-normal">
      {href.length > 150 ? href.slice(0, 150) + "..." : href}
    </span>
    {
      tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-2 opacity-70">
          {tags.map((tag) => (
            <span class="text-xs text-muted font-normal tracking-wider">
              {tag}
            </span>
          ))}
        </div>
      )
    }
  </a>
</div>

<script>
  function updateReadingLinks() {
    document.querySelectorAll("[data-reading-checkbox]").forEach((checkbox) => {
      const wrapper = checkbox.closest("[data-reading-wrapper]");
      if (!wrapper) return;

      const isChecked = (checkbox as HTMLInputElement).checked;
      if (isChecked) {
        wrapper.classList.add("opacity-50");
      } else {
        wrapper.classList.remove("opacity-50");
      }
    });
  }

  // Update on page load
  document.addEventListener("DOMContentLoaded", updateReadingLinks);

  // Update when checkbox changes
  document.addEventListener("change", (e) => {
    if ((e.target as Element)?.getAttribute("data-reading-checkbox") !== null) {
      updateReadingLinks();
    }
  });

  // Update when reading progress is synced across checkboxes
  window.addEventListener("reading-progress-update", updateReadingLinks);
</script>
