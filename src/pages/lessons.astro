---
import BaseLayout from "../layouts/BaseLayout.astro";
import { modules } from "../lib/modules";
import { getLessons } from "../lib/lessons";
import { getLessonUrl, getModuleUrl } from "../lib/lessons";

const lessons = getLessons();
const modulesWithLessons = modules.map((module) => ({
  ...module,
  lessons: lessons
    .filter((lesson) => lesson.data.module === module.id)
    .sort((a, b) => a.data.order - b.data.order),
}));
---

<BaseLayout title="Lessons - PM Learning Tool" description="Complete list of product management lessons">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold mb-4">Lessons</h1>
      <p class="text-lg text-gray-600">Complete learning path for product management</p>
    </div>

    <div class="grid gap-4 md:gap-8 mt-8 mb-8 md:grid-cols-1 lg:grid-cols-2">
      {
        modulesWithLessons.map((module, index) => {
          const moduleHref = getModuleUrl(module.id);
          
          return (
            <div class="module-card">
              <div class="module-card__header">
                <h3>
                  {(index + 1).toLocaleString("en-US", {
                    minimumIntegerDigits: 2,
                    useGrouping: false,
                  })}
                  . {module.title}
                </h3>
              </div>
              <p>{module.description}</p>
              <div class="module-card__footer">
                <span>
                  {module.lessons.length} lesson
                  {module.lessons.length === 1 ? "" : "s"}
                </span>
              </div>
              
              {module.lessons.length > 0 && (
                <div class="lesson-list">
                  <ul>
                    {module.lessons.map((lesson) => {
                      const href = getLessonUrl(lesson);
                      return (
                        <li key={lesson.slug}>
                          <a href={href}>{lesson.data.title}</a>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              )}
            </div>
          );
        })
      }
    </div>
  </section>
</BaseLayout>