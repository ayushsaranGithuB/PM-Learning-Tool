---
import LessonPager from "../../components/LessonPager.astro";
import ReadingList from "../../components/ReadingList.astro";
import QuizModal from "../../components/QuizModal.astro";
import LessonLayout from "../../layouts/LessonLayout.astro";
import { getLessons } from "../../lib/lessons";
import { getFlashcardsForLesson } from "../../lib/flashcards";
import { moduleById } from "../../lib/modules";

export function getStaticPaths() {
  const allLessons = getLessons();

  return allLessons.map((lesson) => {
    const module = moduleById.get(lesson.data.module);

    if (!module) {
      throw new Error(`Unknown module id: ${lesson.data.module}`);
    }

    return {
      params: {
        module: module.path,
        slug: lesson.data.slug,
      },
      props: {
        lesson,
        allLessons,
      },
    };
  });
}

const { lesson, allLessons: lessons } = Astro.props;
const module = moduleById.get(lesson.data.module);

if (!module) {
  throw new Error(`Unknown module id: ${lesson.data.module}`);
}

const currentIndex = lessons.findIndex((entry) => entry.id === lesson.id);
const previous = currentIndex > 0 ? lessons[currentIndex - 1] : undefined;
const next =
  currentIndex < lessons.length - 1 ? lessons[currentIndex + 1] : undefined;
const headings = await lesson.getHeadings();
const Content = lesson.Content;
const flashcards = getFlashcardsForLesson(lesson.data.slug);
---

<LessonLayout title={`${lesson.data.title} | PM Learning Tool`}>
  <article class="lesson-page">
    <header class="page-heading">
      <p class="eyebrow">{module.title}</p>
      <h1 class="max-w-[70%] font-bold">{lesson.data.title}</h1>
      <div class="lesson-meta">
        <span>{lesson.data.estimatedMinutes} min read</span>
        <span>{lesson.data.flashcards.length} flashcards</span>
        <span>{lesson.data.status}</span>
      </div>
    </header>

      <div class="lesson-columns">
        <div class="lesson-article prose">
          <Content />
          <ReadingList items={lesson.data.recommendedReading} lessonSlug={lesson.data.slug} />
          <QuizModal cards={flashcards} title={lesson.data.title} />
          <LessonPager previous={previous} next={next} />
        </div>

        <div></div>
      </div>
    </article>
  </LessonLayout>

  <script is:inline define:vars={{ lessonSlug: lesson.data.slug }}>
    function enhanceInlineLinks() {
      const prose = document.querySelector(".lesson-article.prose");
      if (!prose) return;

      const links = prose.querySelectorAll("a[href^='http']");
      links.forEach((link) => {
        if (link.closest(".reading-link-wrapper") || link.closest(".checklist")) return;

        const wrapper = document.createElement("span");
        wrapper.className = "reading-link-wrapper";

        const label = document.createElement("label");
        label.className = "reading-checkbox";
        label.setAttribute("data-tooltip", "Mark as read");

        const checkbox = document.createElement("input");
        checkbox.type = "checkbox";
        checkbox.className = "reading-checkbox-input";
        checkbox.setAttribute("data-reading-checkbox", "");
        const key = `pm-reading:${lessonSlug}:${link.href}`;
        checkbox.setAttribute("data-key", key);
        checkbox.setAttribute("aria-label", `Mark "${link.textContent.trim()}" as read`);

        if (localStorage.getItem(key) === "true") {
          checkbox.checked = true;
        }

        checkbox.addEventListener("change", () => {
          if (checkbox.checked) {
            localStorage.setItem(key, "true");
          } else {
            localStorage.removeItem(key);
          }
          window.dispatchEvent(new CustomEvent("reading-progress-update"));
        });

        const indicator = document.createElement("span");
        indicator.className = "reading-checkbox-indicator";

        label.appendChild(checkbox);
        label.appendChild(indicator);
        wrapper.appendChild(label);

        link.parentNode.insertBefore(wrapper, link);
        wrapper.appendChild(link);
      });
    }

    document.addEventListener("DOMContentLoaded", () => {
      enhanceInlineLinks();
      // Notify the ReadingList to re-scan all checkboxes
      window.dispatchEvent(new CustomEvent("inline-links-enhanced"));
    });
  </script>
