---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLessonUrl, getLessons } from "../lib/lessons";
import { modules } from "../lib/modules";

const lessons = getLessons();
const totalLessons = lessons.length;
const draftedLessons = lessons.filter((lesson) => lesson.data.status === "draft").length;
const totalReading = lessons.reduce((sum, lesson) => sum + lesson.data.recommendedReading.length, 0);
const modulesWithLessons = modules.map((module) => ({
  ...module,
  lessons: lessons
    .filter((lesson) => lesson.data.module === module.id)
    .sort((a, b) => a.data.order - b.data.order)
}));
---

<BaseLayout title="PM Learning Tool">
  <section class="hero">
    <p class="eyebrow">Notebook</p>
    <h1>Product management notes for builders.</h1>
    <p class="hero__lede">
      A quiet learning guide for engineers and designers moving toward stronger product judgment.
    </p>

    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-card__label">Modules</span>
        <strong>{modules.length}</strong>
      </div>
      <div class="stat-card">
        <span class="stat-card__label">Lessons</span>
        <strong>{totalLessons}</strong>
      </div>
      <div class="stat-card">
        <span class="stat-card__label">Reading Links</span>
        <strong>{totalReading}</strong>
      </div>
      <div class="stat-card">
        <span class="stat-card__label">Drafts</span>
        <strong>{draftedLessons}</strong>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="section-heading">
      <h2>Learning Path</h2>
      <p>Sequential when you want it, browseable when you do not.</p>
    </div>

    <div class="module-grid">
      {modulesWithLessons.map((module) => (
        <article class="module-card">
          <div class="module-card__header">
            <p class="module-card__eyebrow">{module.path}</p>
            <h3><a href={`/${module.path}/`}>{module.title}</a></h3>
          </div>
          <p>{module.description}</p>
          <div class="module-card__footer">
            <span>{module.lessons.length} lesson{module.lessons.length === 1 ? "" : "s"}</span>
            {module.lessons[0] ? <a href={getLessonUrl(module.lessons[0])}>Start here</a> : <span>Coming soon</span>}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>