---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLessonUrl, getLessons } from "../lib/lessons";
import { modules } from "../lib/modules";

const lessons = getLessons();
const modulesWithLessons = modules.map((module) => ({
  ...module,
  lessons: lessons
    .filter((lesson) => lesson.data.module === module.id)
    .sort((a, b) => a.data.order - b.data.order),
}));
---

<BaseLayout title="PM Learning Tool">
  <section class="hero">
    <p class="eyebrow">Notebook</p>
    <h1>Product management notes for builders.</h1>
    <p class="hero__lede">
      A quiet learning guide for engineers and designers moving toward stronger
      product judgment.
    </p>
  </section>

  <section class="content-section">
    <div class="section-heading">
      <h2>Learning Path</h2>
      <p>Sequential when you want it, browseable when you do not.</p>
    </div>

    <div class="module-grid">
      {modulesWithLessons.map((module, index) => {
        const href = module.lessons[0] ? getLessonUrl(module.lessons[0]) : `/${module.path}/`;

        return (
          <a class="module-card module-card--link" href={href}>
            <div class="module-card__header">
              <h3>
                {(index + 1).toLocaleString("en-US", {
                  minimumIntegerDigits: 2,
                  useGrouping: false,
                })}
                . {module.title}
              </h3>
            </div>
            <p>{module.description}</p>
            <div class="module-card__footer">
              <span>
                {module.lessons.length} lesson
                {module.lessons.length === 1 ? "" : "s"}
              </span>
              <span>{module.lessons[0] ? "Start here →" : "Coming soon"}</span>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>
