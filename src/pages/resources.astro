---

<BaseLayout
  title="Resources - PM Learning Tool"
  description="PM courses, blogs, and reading materials"
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-16">
      <h1 class="text-3xl font-bold mb-2">Resources</h1>
      <p class="text-lg text-gray-600">
        PM courses, blogs, and reading materials
      </p>
    </div>

    <div class="mb-24">
      <h2 class="text-2xl font-bold mb-6">PM Courses</h2>
      <ul class="space-y-4 pl-2">
        {
          courses.map((course) => (
            <li>
              <ReadingLink
                href={course.url}
                lessonSlug="resources"
                title={course.title}
              />
            </li>
          ))
        }
      </ul>
    </div>

    <div class="mb-24">
      <h2 class="text-2xl font-bold mb-6">Suggested Reading</h2>

      {
        blogCategories.map((category) => (
          <div>
            <h3 class="text-3xl font-semibold mb-4 mt-14 text-gray-800 pb-2">
              {category.name}
            </h3>
            <ul class="space-y-4 pl-4 mb-10">
              {category.links.map((link) => (
                <li>
                  <ReadingLink
                    href={link.url}
                    lessonSlug="resources"
                    title={link.title}
                    tags={link.tags}
                  />
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mb-24">
      <h2 class="text-2xl font-bold mb-10">Blogs to Follow</h2>

      <ul class="space-y-4 pl-4 mb-10">
        {
          blogs.map((link) => (
            <li>
              <ReadingLink
                href={link.url}
                lessonSlug="resources"
                title={link.title}
                tags={link.tags}
              />
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="text-2xl font-bold mb-6">Books</h2>
      <ul class="space-y-4 pl-2">
        {
          books.map((book) => (
            <li>
              <ReadingLink
                href={book.url}
                lessonSlug="resources"
                title={book.title}
              />
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
