---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Resources - PM Learning Tool" description="PM courses, blogs, and reading materials">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold mb-4">Resources</h1>
      <p class="text-lg text-gray-600">PM courses, blogs, and reading materials</p>
    </div>

    <div class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Recommended PM Courses</h2>
      <ul class="space-y-2">
        <li><a href="https://www.coursera.org/specializations/product-management" class="text-blue-600 hover:text-blue-800 hover:underline">Product Management Specialization - Coursera</a></li>
        <li><a href="https://www.udemy.com/course/productmanagement/" class="text-blue-600 hover:text-blue-800 hover:underline">Product Management Fundamentals - Udemy</a></li>
        <li><a href="https://www.linkedin.com/learning/product-management-foundations" class="text-blue-600 hover:text-blue-800 hover:underline">Product Management Foundations - LinkedIn Learning</a></li>
        <li><a href="https://www.productschool.com/" class="text-blue-600 hover:text-blue-800 hover:underline">Product School Courses</a></li>
      </ul>
    </div>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Suggested Blogs and Reading</h2>
      <ul class="space-y-2">
        <li><a href="https://www.svpg.com/articles" class="text-blue-600 hover:text-blue-800 hover:underline">SVPG - Silicon Valley Product Group</a></li>
        <li><a href="https://www.mindtheproduct.com/" class="text-blue-600 hover:text-blue-800 hover:underline">Mind the Product</a></li>
        <li><a href="https://www.productplan.com/blog/" class="text-blue-600 hover:text-blue-800 hover:underline">ProductPlan Blog</a></li>
        <li><a href="https://www.romanpichler.com/blog/" class="text-blue-600 hover:text-blue-800 hover:underline">Roman Pichler's Product Management Blog</a></li>
        <li><a href="https://blackboxofpm.com/" class="text-blue-600 hover:text-blue-800 hover:underline">The Black Box of Product Management</a></li>
      </ul>
    </div>
    
    <div>
      <h2 class="text-2xl font-bold mb-4">Books</h2>
      <ul class="space-y-2">
        <li><a href="https://www.amazon.com/Inspired-Product-Management-Second/dp/1119387507" class="text-blue-600 hover:text-blue-800 hover:underline">Inspired: How to Create Tech Products Customers Love - Marty Cagan</a></li>
        <li><a href="https://www.amazon.com/Decode-Agile-Management-Engineers-Leading/dp/1732265186" class="text-blue-600 hover:text-blue-800 hover:underline">Decode and Conquer: Answers to Product Management Interviews - Lewis Lin</a></li>
        <li><a href="https://www.amazon.com/Practical-Product-Management-Transform-Productivity/dp/1491927336" class="text-blue-600 hover:text-blue-800 hover:underline">The Practical Product Manager - Robert Siegel</a></li>
        <li><a href="https://www.amazon.com/Design-Everyday-Things-Donald-Norman/dp/1452637404" class="text-blue-600 hover:text-blue-800 hover:underline">The Design of Everyday Things - Don Norman</a></li>
      </ul>
    </div>
  </section>
</BaseLayout>
