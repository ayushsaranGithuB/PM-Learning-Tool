---
import CourseNav from "../components/CourseNav.astro";
import { getLessons } from "../lib/lessons";
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/global.css";
import { modules } from "../lib/modules";

type Props = {
  title: string;
  description?: string;
};

const {
  title,
  description = "A calm, technical notebook for learning product management.",
} = Astro.props;
const lessons = getLessons();

const totalLessons = lessons.length;
const draftedLessons = lessons.filter(
  (lesson) => lesson.data.status === "draft",
).length;
const totalReading = lessons.reduce(
  (sum, lesson) => sum + lesson.data.recommendedReading.length,
  0,
);

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      const savedTheme = localStorage.getItem("pm-learning-theme");
      const systemTheme = window.matchMedia("(prefers-color-scheme: dark)")
        .matches
        ? "dark"
        : "light";
      document.documentElement.dataset.theme = savedTheme || systemTheme;
    </script>
  </head>
  <body>
    <div class="app-shell">
      <header class="topbar">
        <CourseNav lessons={lessons} currentPath={Astro.url.pathname} />
        <div class="topbar__actions">
          <ThemeToggle />
        </div>
      </header>

      <main class="main-shell">
        <div class="page-shell">
          <slot />
        </div>
      </main>

      <footer class="mt-12 pt-6 pb-8 border-t-2 border-gray-200 dark:border-gray-700">
        <div class="flex flex-wrap justify-between gap-4 items-center px-0 py-6">
          <div>
            <h3 class="mb-0">PM Learning Tool.</h3>
            <p class="text-xs tracking-wide mt-1">A personal notebook for builders learning product management.</p>
          </div>
          <div class="flex flex-wrap gap-4 justify-center">
            <div class="text-center">
              <span class="text-xs text-gray-500 dark:text-gray-400">Modules</span>
              <strong class="block text-lg tracking-tight">{modules.length}</strong>
            </div>
            <div class="text-center">
              <span class="text-xs text-gray-500 dark:text-gray-400">Lessons</span>
              <strong class="block text-lg tracking-tight">{totalLessons}</strong>
            </div>
            <div class="text-center">
              <span class="text-xs text-gray-500 dark:text-gray-400">Reading Links</span>
              <strong class="block text-lg tracking-tight">{totalReading}</strong>
            </div>
            <div class="text-center">
              <span class="text-xs text-gray-500 dark:text-gray-400">Drafts</span>
              <strong class="block text-lg tracking-tight">{draftedLessons}</strong>
            </div>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
